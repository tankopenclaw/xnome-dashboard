# PostgreSQL connection string
# Example: postgres://devuser:password@127.0.0.1:5432/anome
DATABASE_URL=

# Lark bot webhook URL
# Example: https://open.larksuite.com/open-apis/bot/v2/hook/xxxx
LARK_WEBHOOK_URL=

# Poll interval in minutes (default 10)
POLL_INTERVAL_MINUTES=10

# Optional: comma-separated task_group ids, e.g. 1,2,3
# Empty means all groups
GROUP_IDS=

# Optional: enabled review sources (comma-separated)
# supported now: reward_claims, task_reviews
REVIEW_SOURCES=reward_claims

# Future-proof task review source
# keep false until backend API/table is implemented
TASK_REVIEW_ENABLED=false

# Optional custom SQL for task review pending query (future)
# Must return columns:
# review_id, group_id, group_name, user_id, nickname, email, submitted_at, task_name
TASK_PENDING_SQL=

# State file path
STATE_FILE=./state.json
